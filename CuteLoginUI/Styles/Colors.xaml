<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#C9B5FF"/>

    <!-- Card -->
    <SolidColorBrush x:Key="CardBrush" Color="#FFF8F8"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#9B6DFF"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TitleBrush" Color="#5D3DA8"/>
    <SolidColorBrush x:Key="SubtitleBrush" Color="#777777"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBrush" Color="#FFFFFF"/>

    <!-- Shadow -->
    <SolidColorBrush x:Key="ShadowBrush" Color="#40000000"/>

</ResourceDictionary>