<Window x:Class="CuteLoginUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cute Login"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#D9C6FF">

    <Grid>


        <!-- Background -->
        <Border Background="#D9C6FF"/>

        <!-- Decorative Left Cloud -->
        <Image Source="/Assets/Images/CloudLeft.png"
               Width="170"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="182,64,0,0" />

        <!-- Decorative Right Cloud -->
        <Image Source="Assets/Images/CloudRight.png"
               Width="170"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,262,190,0" />

        <!-- Bottom Left Plant -->
        <Image Source="Assets/Images/Plant.png"
               Width="160"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Margin="195,0,0,-9" />

        <!-- Bottom Right Flower -->
        <Image Source="Assets/Images/Flower.png"
               Width="120"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,224,-29"/>

        <!-- Main Card -->
        <!-- Main Card -->
        <Border Width="620"
        Height="800"
        MaxWidth="620"
        MaxHeight="680"
        Background="White"
        CornerRadius="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="55"
                  ShadowDepth="0"
                  Color="#5A3AC8"
                  Opacity="0.20"/>

            </Border.Effect>

            <Grid>

                <!-- Heart -->

                <Button Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0,20,23,0"
        Click="BilvaLogo_Click" Width="61">

                    <Image x:Name="imgBilvaLogo"
       Source="Assets/Images/BilvaLogo.png"
           Width="37"
           Height="42"
           HorizontalAlignment="Right"
           VerticalAlignment="Top"
           Margin="0,5,27,0"/>
                </Button>

                <!-- Character -->


                <Image x:Name="CharacterImage"
       Source="Assets/Images/Character.png"
       Width="230"
       Height="216"
       HorizontalAlignment="Center"
       VerticalAlignment="Top"
       Margin="0,4,0,0"
       Stretch="Uniform">



                    <Image.RenderTransform>
                        <TranslateTransform/>
                    </Image.RenderTransform>

                </Image>

                <!-- Welcome Section -->
                <StackPanel VerticalAlignment="Top"
            Margin="0,190,0,0"
            HorizontalAlignment="Center">

                    <TextBlock Text="Welcome Back"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#5C3BB8"
                   HorizontalAlignment="Center"/>

                    <TextBlock Text="Login to continue your journey"
                   FontSize="15"
                   Foreground="#8E8E8E"
                   Margin="0,8,0,0"
                   HorizontalAlignment="Center"/>

                </StackPanel>

                <!-- Login Area -->
                <StackPanel x:Name="LoginPanel"
            Width="470"
            VerticalAlignment="Top"
            Margin="0,210,0,0"
            HorizontalAlignment="Center">

                    <!-- Username -->

                    <!-- Username -->

                    <TextBlock Text="Username"
                   FontWeight="SemiBold"
                   Foreground="#666666"
                   />

                    <Border Height="58"
        Background="#F7F4FF"
        CornerRadius="25">

                        <Border.Effect>

                            <DropShadowEffect BlurRadius="8"
                          ShadowDepth="0"
                          Opacity="0.12"/>

                        </Border.Effect>

                        <Grid Margin="18,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="Assets/Icons/User.png"
                       Height="20"
                       VerticalAlignment="Center" Margin="3,0,22,0" RenderTransformOrigin="-0.222,0.471"/>

                            <TextBox x:Name="txtUsername"
         Grid.Column="1"
         FontSize="16"
         BorderThickness="0"
         Background="Transparent"
         VerticalContentAlignment="Center"
         Text="Username"
         Foreground="Gray"
         GotFocus="txtUsername_GotFocus"
         LostFocus="txtUsername_LostFocus"/>

                        </Grid>

                    </Border>

                    <!-- Password -->
                    <TextBlock Text="Password"
           FontWeight="SemiBold"
           Foreground="#666666"
           Margin="5,0,0,8"/>

                    <Border Height="58"
        Background="#F7F4FF"
        CornerRadius="25"
        Margin="0,0,0,10">

                        <Grid Margin="18,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="Assets/Icons/Lock.png"
               Height="52"
               VerticalAlignment="Top" Margin="0,12,12,0"/>

                            <Grid Grid.Column="1">

                                <TextBlock x:Name="txtPasswordPlaceholder"
               Text="Password"
               Foreground="Gray"
               VerticalAlignment="Center"
               Margin="2,0,0,0"
               IsHitTestVisible="False"/>

                                <PasswordBox x:Name="txtPassword"
                 VerticalContentAlignment="Center"
                 VerticalAlignment="Center"
                 BorderThickness="0"
                 Background="Transparent"
                 FontSize="16"
                 GotFocus="txtPassword_GotFocus"
                 LostFocus="txtPassword_LostFocus"/>

                                <TextBox x:Name="txtPasswordVisible"
             Visibility="Collapsed"
             VerticalContentAlignment="Center"
             VerticalAlignment="Center"
             BorderThickness="0"
             Background="Transparent"
             FontSize="16"/>

                            </Grid>

                            <Button Grid.Column="2"
        Width="24"
        Height="24"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        Click="EyeButton_Click">

                                <Image x:Name="imgEye"
       Source="Assets/Icons/EyeClosed.png"
       Width="18"
       Height="18"/>

                            </Button>

                        </Grid>

                    </Border>
                    <!-- Login Button -->
                    <Button x:Name="btnLogin"
        Height="60"
        Click="btnLogin_Click"
        FontSize="18"
        FontWeight="Bold"
        Foreground="White"
        BorderThickness="0"
        Cursor="Hand"
        Content="LOGIN">

                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">

                                <Border CornerRadius="30">

                                    <Border.Background>

                                        <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">

                                            <GradientStop Color="#B874FF"
                                      Offset="0"/>

                                            <GradientStop Color="#8A5BFF"
                                      Offset="1"/>

                                        </LinearGradientBrush>

                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18"
                      ShadowDepth="0"
                      Color="#8A5BFF"
                      Opacity="0.35"/>
                                    </Border.Effect>

                                    <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                                </Border>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                    <!-- Forgot Password -->
                    <TextBlock Text="Forgot Password?"
           HorizontalAlignment="Right"
           Foreground="#8F64FF"
           FontWeight="SemiBold"
           Margin="0,0,0,20"
           Cursor="Hand"
           MouseLeftButtonUp="ForgotPassword_Click"/>

                    <!-- Divider -->
                    <Grid Margin="0,28">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Rectangle Height="1"
               Fill="#E3E3E3"
               VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
               Text="OR"
               Margin="15,0"
               Foreground="#999999"
               FontWeight="SemiBold"/>

                        <Rectangle Grid.Column="2"
               Height="1"
               Fill="#E3E3E3"
               VerticalAlignment="Center"/>

                    </Grid>

                    <!-- Social Login -->
                    <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,20,0,0">

                        <!-- Google -->
                        <Button Width="60"
            Height="60"
            Margin="8"
            Background="White"
            BorderBrush="#EEEEEE"
            Cursor="Hand"
            Click="Google_Click">

                            <Image Source="Assets/Icons/Google.png"
               Width="26"
               Height="26"/>

                        </Button>

                        <!-- Apple -->
                        <Button Width="60"
            Height="60"
            Margin="8"
            Background="White"
            BorderBrush="#EEEEEE"
            Cursor="Hand"
            Click="Apple_Click">

                            <Image Source="Assets/Icons/Apple.png"
               Width="26"
               Height="26"/>

                        </Button>

                        <!-- Facebook -->
                        <Button Width="60"
            Height="60"
            Margin="8"
            Background="White"
            BorderBrush="#EEEEEE"
            Cursor="Hand"
            Click="Facebook_Click">

                            <Image Source="Assets/Icons/Facebook.png"
               Width="26"
               Height="26"/>

                        </Button>

                    </StackPanel>

                    <!-- Sign Up -->
                    <TextBlock Margin="0,20,0,25"
           HorizontalAlignment="Center"
           FontSize="15">

    <Run Text="Don't have an account? "/>

    <Run Text="Sign Up"
         Foreground="#8A5BFF"
         FontWeight="Bold"
         MouseDown="SignUp_Click"/>

                    </TextBlock>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>